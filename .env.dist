PUBLIC_PROXY_POOL = ""
# Used only for bare IPs without a port (e.g. 203.0.113.1 → http://203.0.113.1:PUBLIC_PROXY_DEFAULT_PORT)
PUBLIC_PROXY_DEFAULT_PORT = "8080"
